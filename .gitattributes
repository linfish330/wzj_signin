# Set the default behavior to automatically normalize line endings.
* text=auto

# Declare files that should always have LF line endings on checkout.
*.go text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
Dockerfile text eol=lf
scripts/wzj_signin text eol=lf

# Declare files that should always have CRLF line endings on checkout.
*.ps1 text eol=crlf
*.bat text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
